using Gtk 4.0;
using Adw 1;

template $AutomataWindow: Adw.ApplicationWindow {
  title: _("Automata");
  default-width: 800;
  default-height: 600;
  width-request: 360;
  height-request: 360;

  ShortcutController {
    scope: managed;

    Shortcut {
      action: 'activate';
      trigger: '<Space>';
    }
  }

  Adw.Breakpoint {
    condition ("max-width: 600px")

    setters {
      split_view.collapsed: true;
    }
  }

  content: Adw.ToastOverlay toast_overlay {
    Adw.NavigationSplitView split_view {
      show-content: true;
      sidebar-width-fraction: 0.25;

      [sidebar]
      Adw.NavigationPage sidebar_page {
        title: _("Sidebar");

        Adw.ToolbarView {
          [top]
          Adw.HeaderBar {
            [start]
            Adw.SplitButton {
              Adw.ButtonContent {
                label: _("New Task");
                icon-name: "list-add-symbolic";
              }

              action-name: "app.task.create";
              menu-model: create_menu;
            }

            [end]
            MenuButton {
              primary: true;
              icon-name: "open-menu-symbolic";
              tooltip-text: _("Main Menu");
              menu-model: primary_menu;
            }
          }

          ListBox sidebar {
            selection-mode: single;

            styles [
              "navigation-sidebar",
            ]
          }
        }
      }

      Adw.NavigationPage content_page {
        title: _("Сегодня");

        Adw.ToolbarView {
          [top]
          Adw.HeaderBar {}

          Stack view_stack {
            transition-type: slide_up_down;
          }

          // Adw.StatusPage {
          //   title: _("Automata");
          //   icon-name: "com.tenderowl.automata";
          //   description: _("Focus what matter");
          // }
        }
      }
    }
  };
}

menu primary_menu {
  section {
    item {
      label: _("_Preferences");
      action: "app.preferences";
    }

    item {
      label: _("_Keyboard Shortcuts");
      action: "app.shortcuts";
    }

    item {
      label: _("_About Automata");
      action: "app.about";
    }
  }
}

menu create_menu {
  section {
    item {
      label: _("New Project");
      action: "app.project.create";
    }

    item {
      label: _("New Note");
      action: "app.note.create";
    }
  }
}
